# Защита служебных файлов и директорий

<FilesMatch "\.(log|sql|md|json|lock|example\.php)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

# Защита директорий
RedirectMatch 403 ^/booking/lib/
RedirectMatch 403 ^/booking/cron/
# Временно открыт setup.php — УДАЛИТЬ после установки!
RedirectMatch 403 ^/booking/migrations/(?!setup\.php)
RedirectMatch 403 ^/booking/logs/
RedirectMatch 403 ^/booking/templates/

# PWA manifest MIME type
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>

